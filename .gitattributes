# Binary assets must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.exr binary
*.hdr binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary
*.dll binary
*.so binary
*.dylib binary
*.ttf binary
*.otf binary

# Unity writes empty YAML values with a trailing space by design.
*.meta whitespace=-blank-at-eol
*.unity whitespace=-blank-at-eol
*.prefab whitespace=-blank-at-eol
*.asset whitespace=-blank-at-eol
*.mat whitespace=-blank-at-eol
*.anim whitespace=-blank-at-eol
*.controller whitespace=-blank-at-eol
*.overrideController whitespace=-blank-at-eol
*.physicMaterial whitespace=-blank-at-eol
*.wlt whitespace=-blank-at-eol
